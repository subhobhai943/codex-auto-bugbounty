{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex Auto Bug Bounty Skill Output",
  "type": "object",
  "properties": {
    "bugcrowd_report": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "weakness_type": { "type": "string" },
        "severity": { "type": "string" },
        "asset": { "type": "string" },
        "environment": { "type": "string" },
        "steps_to_reproduce": { "type": "array", "items": { "type": "string" } },
        "expected_result": { "type": "string" },
        "actual_result": { "type": "string" },
        "impact": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "path": { "type": "string" },
              "type": { "type": "string" }
            },
            "required": ["label", "path"]
          }
        }
      },
      "required": ["title", "weakness_type", "severity", "asset", "steps_to_reproduce", "impact"]
    },
    "submission_guide": {
      "type": "object",
      "properties": {
        "checklist": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["checklist"]
    }
  },
  "required": ["bugcrowd_report", "submission_guide"]
}
